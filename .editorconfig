# Aligns with Spotless (prettier + prettier-plugin-java) via spotless-maven-plugin.
# https://github.com/diffplug/spotless
# https://github.com/jhipster/prettier-java

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_style = space
indent_size = 2
tab_width = 2
max_line_length = 80

[*.xml]
indent_style = tab
indent_size = 4
tab_width = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.properties]
indent_style = space
indent_size = 4

[*.md]
indent_style = space
indent_size = 2

[*.cmd]
end_of_line = crlf
